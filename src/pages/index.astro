) skew(0, 0);-moz-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);-ms-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0)" class="about-pill _01"><div>Accessible</div></div><div style="-webkit-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);-moz-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);-ms-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0)" class="about-pill _02"><div>Extensible</div></div><div style="-webkit-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);-moz-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);-ms-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0);transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(-90deg) skew(0, 0)" class="about-pill _03"><div>Build</div></div></div><img src="/assets/cdn/69577d21-695c30538612adfd40892fdc_Ellipse-1247.svg" loading="lazy" alt="About Slate" class="about-slate"/><img src="/assets/cdn/69577d21-695c3055bf38a6400f967745_Group-3.svg" loading="lazy" style="-webkit-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-moz-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);-ms-transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0);transform:translate3d(0, -50rem, 0) scale3d(1, 1, 1) rotateX(0) rotateY(0) rotateZ(0) skew(0, 0)" alt="About Continue" class="about-continue"/></div></div></div></div></section><section id="tasks" aria-labelledby="tasks-heading" class="section solutions"><h2 id="tasks-heading" class="sr-only">Tasks that build public trust</h2><div class="wrapper solutions"><div class="solutions-top"><div data-w-id="069fd41b-bb5d-7aca-9802-a30fdba21589" class="cta-1 _01"><span class="solutions-text solution">Tasks</span><span class="solutions-text">That</span><span class="solutions-text grow">Build</span></div><div data-w-id="d1fef72e-ffe9-0e82-0335-a03831e5ad16" class="cta-1 _01"><span data-w-id="d1fef72e-ffe9-0e82-0335-a03831e5ad19" class="solutions-text">Public Trust</span></div><p data-w-id="2aa23eaa-9fac-9d39-2e16-78c3d460c2d7" class="solution-para">Every project gives a visitor a working path, named evidence, and one useful next step.</p></div><div data-w-id="2ad55c9d-5c1c-f851-265e-557a3005a8ea" data-current="Tab 1" data-easing="ease" data-duration-in="300" data-duration-out="100" class="solutions-tabs w-tabs"><div class="tabs-menu w-tab-menu"><a data-w-tab="Tab 1" data-w-id="2ad55c9d-5c1c-f851-265e-557a3005a8ec" class="solution-tab _01 w-inline-block w-tab-link w--current"><div class="solution-content _01"><h3 class="solution-title">Try civic demo</h3><div data-w-id="21ae64ab-e50a-f6fd-02fd-4faac95bb025" class="solution-details"><p class="solution-desp">Let a person try the public task before asking them to trust the claim.</p><img src="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp" loading="lazy" sizes="100vw" srcset="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-500.webp 500w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-800.webp 800w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-1080.webp 1080w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp 1180w" alt="Solution Img" class="solution-img"/></div></div></a><a data-w-tab="Tab 2" data-w-id="e4e9b0ff-335b-78b6-2baf-3f8dfaf592ab" class="solution-tab _02 w-inline-block w-tab-link"><div class="solution-content _02"><h3 class="solution-title">Inspect City sources</h3><div data-w-id="e4e9b0ff-335b-78b6-2baf-3f8dfaf592af" class="solution-details"><p class="solution-desp">Link the official public records and show which source supports each result.</p><img sizes="100vw" srcset="/assets/cdn/69577d21-695c671e58e8d8de84ed006d_Frame-43-2--p-500.png 500w, /assets/cdn/69577d21-695c671e58e8d8de84ed006d_Frame-43-2--p-800.png 800w, /assets/cdn/69577d21-695c671e58e8d8de84ed006d_Frame-43-2--p-1080.png 1080w, /assets/cdn/69577d21-695c671e58e8d8de84ed006d_Frame-43-2-.png 1180w" alt="Solution Img" src="/assets/cdn/69577d21-695c671e58e8d8de84ed006d_Frame-43-2-.png" loading="lazy" class="solution-img _02"/></div></div></a><a data-w-tab="Tab 3" data-w-id="0a5f5e39-220c-f4fd-242c-7cd996e45014" class="solution-tab _03 w-inline-block w-tab-link"><div class="solution-content _03"><h3 class="solution-title">Read test evidence</h3><div data-w-id="0a5f5e39-220c-f4fd-242c-7cd996e45018" class="solution-details"><p class="solution-desp">Save a browser check, source receipts, and a trace that another person can inspect.</p><img sizes="100vw" srcset="/assets/cdn/69577d21-695c6a25460afbb4d8282405_Frame-43-3--p-500.png 500w, /assets/cdn/69577d21-695c6a25460afbb4d8282405_Frame-43-3--p-800.png 800w, /assets/cdn/69577d21-695c6a25460afbb4d8282405_Frame-43-3--p-1080.png 1080w, /assets/cdn/69577d21-695c6a25460afbb4d8282405_Frame-43-3-.png 1180w" alt="Solution Img" src="/assets/cdn/69577d21-695c6a25460afbb4d8282405_Frame-43-3-.png" loading="lazy" class="solution-img _02"/></div></div></a><a data-w-tab="Tab 4" data-w-id="4ab9e438-b23a-1915-ba15-1fbaa57dede0" class="solution-tab _04 w-inline-block w-tab-link"><div class="solution-content _04"><h3 class="solution-title">Follow build stories</h3><div data-w-id="4ab9e438-b23a-1915-ba15-1fbaa57dede4" class="solution-details"><p class="solution-desp">Read the build story, inspect the artifacts, and repeat one bounded test.</p><img sizes="100vw" srcset="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-500.webp 500w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-800.webp 800w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-1080.webp 1080w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp 1180w" alt="Solution Img" src="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp" loading="lazy" class="solution-img"/></div></div></a><a data-w-tab="Tab 5" data-w-id="fdbb5480-7168-d746-54cf-040f950d9926" class="solution-tab _05 w-inline-block w-tab-link"><div class="solution-content _05"><h3 class="solution-title">Add local AI</h3><div data-w-id="fdbb5480-7168-d746-54cf-040f950d992a" class="solution-details"><p class="solution-desp">Keep local model experiments separate from the public result and show every tool call.</p><img sizes="100vw" srcset="/assets/cdn/69577d21-695c6b4a77c332fead8503b8_Frame-43-4--p-500.png 500w, /assets/cdn/69577d21-695c6b4a77c332fead8503b8_Frame-43-4--p-800.png 800w, /assets/cdn/69577d21-695c6b4a77c332fead8503b8_Frame-43-4--p-1080.png 1080w, /assets/cdn/69577d21-695c6b4a77c332fead8503b8_Frame-43-4-.png 1180w" alt="Solution Img" src="/assets/cdn/69577d21-695c6b4a77c332fead8503b8_Frame-43-4-.png" loading="lazy" class="solution-img"/></div></div></a><a data-w-tab="Tab 6" data-w-id="4f29ed70-ba11-18d2-d181-4e19e5df83c9" class="solution-tab _06 w-inline-block w-tab-link"><div class="solution-content _06"><h3 class="solution-title">Open code</h3><div data-w-id="4f29ed70-ba11-18d2-d181-4e19e5df83cd" class="solution-details"><p class="solution-desp">Publish a tested starting path so another builder can study and extend the work.</p><img sizes="100vw" srcset="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-500.webp 500w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-800.webp 800w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43-p-1080.webp 1080w, /assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp 1180w" alt="Solution Img" src="/assets/cdn/69577d21-695c6122e75cb6846ffe3159_Frame-43.webp" loading="lazy" class="solution-img"/></div></div></a></div><div class="tabs-content w-tab-content"><div data-w-tab="Tab 1" class="w-tab-pane w--tab-active"></div><div data-w-tab="Tab 2" class="w-tab-pane"></div><div data-w-tab="Tab 3" class="w-tab-pane"></div><div data-w-tab="Tab 4" class="w-tab-pane"></div><div data-w-tab="Tab 5" class="w-tab-pane"></div><div data-w-tab="Tab 6" class="w-tab-pane"></div></div></div></div><img src="/assets/cdn/69577d21-695c43993704337491b9937a_Group-2147229905.svg" loading="lazy" alt="Solutions Banner" class="solutions-banner"/><img src="/assets/cdn/69577d21-695dafa92223786591521ed5_-.svg" loading="lazy" data-w-id="1218dfb9-16be-3473-a8e9-60ca0b6b4cb1" alt="Solution Thump" class="solution-thump _01"/><img src="/assets/cdn/69577d21-695dafacbe373207d924aad2_-.svg" loading="lazy" data-w-id="24cdd00b-cac1-2665-b896-8dda05b4a4f1" alt="Solution Thump" class="solution-thump _02"/></section><section data-w-id="52d243ab-cbf4-4645-0cfe-02a4ec90b428" class="section ideas" aria-labelledby="process-heading"><h2 id="process-heading" class="sr-only">Build, then show the work</h2><div class="container"><div class="wrapper ideas"><div class="solutions-top ideas-life"><div data-w-id="1fbc799c-cafa-0d1c-b38f-535917e88aec" class="cta-1 _01"><span class="solutions-text ideas-text">Build</span><span class="solutions-text ideas-text">Then</span><span class="solutions-text ideas">Show</span><span class="solutions-text ideas-text">The</span><span class="solutions-text ideas-text">Work</span></div><p data-w-id="1fbc799c-cafa-0d1c-b38f-535917e88af6" class="solution-para ideas">A project earns a place here when the useful path works and the evidence is visible.</p></div><div data-w-id="cc0a1021-c011-130e-0e84-9f0fd851cd3e" class="solutions-middle"><div class="arrow-block"><img src="/assets/cdn/69577d21-695db2c257058bb1c03fc60c_Vector.svg" loading="lazy" alt="Idea Arrow" class="idea-arrow"/></div><div class="solution-card _01"><h3 class="discover-text">01 - Start with a person</h3><div class="discover-flex"><p class="discover-para">Write down who may use the project and the small task they need to complete.</p><img src="/assets/cdn/69577d21-695d04aad564008003d6c8fb_Frame-43.png" loading="lazy" alt="Discover Icon" class="discover-icon"/></div></div><div class="solution-card _02"><h3 class="discover-text">02 - Use named sources</h3><div class="discover-flex"><p class="discover-para">Build the shortest useful path and keep every source close to the claim it supports.</p><img src="/assets/cdn/69577d21-695d0708ba94a1428e852443_Frame-43-1-.png" loading="lazy" alt="Discover Icon" class="discover-icon"/></div></div><div class="solution-card _03"><h3 class="discover-text">03 - Test and publish</h3><div class="discover-flex"><p class="discover-para">Run known cases, save the results, name what failed, and invite the next builder.</p><img src="/assets/cdn/69577d21-695d07aa037458dbd0855120_Frame-43-2-.png" loading="lazy" alt="Discover Icon" class="discover-icon"/></div></div></div><div class="idea-rive"><canvas style="height:100%;width:100%"></canvas></div></div></div></section><section id="projects" aria-labelledby="projects-heading" class="section home-blog"><h2 id="projects-heading" class="sr-only">Showing the proof</h2><div class="container"><div class="wrapper home-work"><div class="solutions-top ideas"><div data-w-id="66c8c2c8-42f0-da05-fa9d-212149925b6c" class="cta-1 _01"><span class="solutions-text ideas-text">Showing</span><span class="solutions-text ideas-text">The</span><div class="header-block"><span class="solutions-text dark-text">Pr     of</span><img src="/assets/cdn/69577d21-695d5e5277ee090d03ab0b06_Group-12.svg" loading="lazy" alt="Work Icon" class="work-icon"/></div></div><p data-w-id="66c8c2c8-42f0-da05-fa9d-212149925b77" class="solution-para home-blog">Four views of Shakti show the live result, the five borough sample, the source trace, and the no AI public runtime.</p></div><div class="collection-list-wrapper w-dyn-list"><div role="list" class="collection-list blog w-dyn-items"><div data-w-id="d4a31bf9-e526-19a9-575a-112ac17dd66b" role="listitem" class="w-dyn-item"><a data-w-id="092f2a47-44bd-5497-2d94-8cabb3533227" href="https://shakti.dharmicdata.org" class="blog-item w-inline-block"><div class="hover-block"><img src="/dharmic-assets/shakti-live-result.png" loading="eager" style="opacity:1" alt="Shakti project evidence" class="blog-image"/><img src="/dharmic-assets/shakti-live-result.png" loading="eager" style="opacity:0" alt="Shakti project evidence" class="blog-image hover"/></div><div class="blog-detail"><h3 class="blog-name">Live Shakti result</h3></div></a></div><div data-w-id="d4a31bf9-e526-19a9-575a-112ac17dd66b" role="listitem" class="w-dyn-item"><a data-w-id="092f2a47-44bd-5497-2d94-8cabb3533227" href="https://github.com/ChaiWithJai/shakti-seva-studio/blob/main/docs/evaluation.md" class="blog-item w-inline-block"><div class="hover-block"><img src="/dharmic-assets/five-borough-eval-map.svg" loading="eager" style="opacity:1" alt="Shakti project evidence" class="blog-image"/><img src="/dharmic-assets/five-borough-eval-map.svg" loading="eager" style="opacity:0" alt="Shakti project evidence" class="blog-image hover"/></div><div class="blog-detail"><h3 class="blog-name">Five borough evaluation</h3></div></a></div><div data-w-id="d4a31bf9-e526-19a9-575a-112ac17dd66b" role="listitem" class="w-dyn-item"><a data-w-id="092f2a47-44bd-5497-2d94-8cabb3533227" href="https://github.com/ChaiWithJai/shakti-seva-studio/blob/main/evals/baseline/netlify-production.json" class="blog-item w-inline-block"><div class="hover-block"><img src="/dharmic-assets/shakti-sources-trace.png" loading="eager" style="opacity:1" alt="Shakti project evidence" class="blog-image"/><img src="/dharmic-assets/shakti-sources-trace.png" loading="eager" style="opacity:0" alt="Shakti project evidence" class="blog-image hover"/></div><div class="blog-detail"><h3 class="blog-name">Sources and trace</h3></div></a></div><div data-w-id="d4a31bf9-e526-19a9-575a-112ac17dd66b" role="listitem" class="w-dyn-item"><a data-w-id="092f2a47-44bd-5497-2d94-8cabb3533227" href="https://shakti.dharmicdata.org/api/health" class="blog-item w-inline-block"><div class="hover-block"><img src="/dharmic-assets/shakti-no-ai.png" loading="eager" style="opacity:1" alt="Shakti project evidence" class="blog-image"/><img src="/dharmic-assets/shakti-no-ai.png" loading="eager" style="opacity:0" alt="Shakti project evidence" class="blog-image hover"/></div><div class="blog-detail"><h3 class="blog-name">Public runtime: no AI</h3></div></a></div></div></div></div></div></section><section id="proof" aria-labelledby="proof-heading" class="section faq"><h2 id="proof-heading" class="sr-only">Questions we answer</h2><div class="container"><div class="wrapper faq"><div class="solutions-top faq"><div class="cta-1 _01"><span class="solutions-text">Questions</span><span class="solutions-text digital">We Answer</span></div><p class="solution-para faq">Direct answers about public data, local AI, proof, and what is available today.</p></div><div class="faq-lists"><details class="dharmic-faq"><summary>Does the public Shakti result use AI?</summary><p>No. Ordinary code handles the address match, City joins, privacy treatment, counts, and next step.</p></details><details class="dharmic-faq"><summary>What did the five borough test prove?</summary><p>Thirty fixed records from each borough passed the privacy scan and trace check. That does not prove every City address will match.</p></details><details class="dharmic-faq"><summary>Where does local AI fit?</summary><p>The local research edition can use Hermes to explain a treated packet and inspect tool calls. A model cannot change the source record or choose the public next step.</p></details>{calendarUrl && <a class="primary-button dharmic-calendar" href={calendarUrl}>Book paid office hours</a>}</div></div></div></section><div class="blog-bg"><section data-wf--blog-section--variant="base" class="section blogs"><div class="container"><div class="wrapper blogs"><div class="solutions-top pricing"><div data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d91" class="cta-1 _01"><span class="solutions-text">Technical</span><span class="solutions-text">&amp;</span><span class="solutions-text digital">Build</span><span class="solutions-text">Stories</span></div><p data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9a" class="solution-para blogs">Jai walks through the terminal, code, traces, and dated results behind each experiment.</p></div><h2 data-w-id="8c8a20e4-5cfd-da20-a147-35f1fa492aa2" class="related-blogs">Latest from the vlog</h2><div class="blog-list-wrapper w-dyn-list"><div role="list" class="blog-list w-dyn-items"><div data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9e" role="listitem" class="w-dyn-item"><a data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9f" href="/vlog/how-we-built-shakti" class="insight-item w-inline-block"><div class="overflow insight"><img src="/assets/cdn/69579f06-695e3e9fb1040be4bbd28a16_Blog-Image-1.webp" loading="lazy" alt="Insight Image" sizes="100vw" srcset="/assets/cdn/69579f06-695e3e9fb1040be4bbd28a16_Blog-Image-1-p-500.webp 500w, /assets/cdn/69579f06-695e3e9fb1040be4bbd28a16_Blog-Image-1-p-800.webp 800w, /assets/cdn/69579f06-695e3e9fb1040be4bbd28a16_Blog-Image-1-p-1080.webp 1080w, /assets/cdn/69579f06-695e3e9fb1040be4bbd28a16_Blog-Image-1.webp 1160w" class="insight-image"/></div><div class="insight-detail"><h3 class="insight-name">How we built Shakti without putting AI in the critical path</h3><p class="insight-para">Follow one address through City data, a source trace, and the separate local model path.</p></div></a></div><div data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9e" role="listitem" class="w-dyn-item"><a data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9f" href="/vlog/how-we-built-shakti" class="insight-item w-inline-block"><div class="overflow insight"><img src="/assets/cdn/69579f06-695e40f235b1cf8a899e927e_Blog-Image-2.webp" loading="lazy" alt="Insight Image" sizes="100vw" srcset="/assets/cdn/69579f06-695e40f235b1cf8a899e927e_Blog-Image-2-p-500.webp 500w, /assets/cdn/69579f06-695e40f235b1cf8a899e927e_Blog-Image-2-p-800.webp 800w, /assets/cdn/69579f06-695e40f235b1cf8a899e927e_Blog-Image-2-p-1080.webp 1080w, /assets/cdn/69579f06-695e40f235b1cf8a899e927e_Blog-Image-2.webp 1160w" class="insight-image"/></div><div class="insight-detail"><h3 class="insight-name">Chapter: address, HPD, and the NYC BIN</h3><p class="insight-para">Learn why one building can have several public names and one shared City identifier.</p></div></a></div><div data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9e" role="listitem" class="w-dyn-item"><a data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9f" href="/vlog/how-we-built-shakti" class="insight-item w-inline-block"><div class="overflow insight"><img src="/assets/cdn/69579f06-695e42a312f86a6d0f39fba0_Blog-Image-3.webp" loading="lazy" alt="Insight Image" sizes="100vw" srcset="/assets/cdn/69579f06-695e42a312f86a6d0f39fba0_Blog-Image-3-p-500.webp 500w, /assets/cdn/69579f06-695e42a312f86a6d0f39fba0_Blog-Image-3-p-800.webp 800w, /assets/cdn/69579f06-695e42a312f86a6d0f39fba0_Blog-Image-3-p-1080.webp 1080w, /assets/cdn/69579f06-695e42a312f86a6d0f39fba0_Blog-Image-3.webp 1160w" class="insight-image"/></div><div class="insight-detail"><h3 class="insight-name">Chapter: the five borough sample</h3><p class="insight-para">Inspect the 150 fixed records, privacy scan, trace check, and test limits.</p></div></a></div><div data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9e" role="listitem" class="w-dyn-item"><a data-w-id="7d525d6d-bec1-3cbb-7f49-2e137da90d9f" href="/vlog/how-we-built-shakti" class="insight-item w-inline-block"><div class="overflow insight"><img src="/assets/cdn/69579f06-695e43370c5edcca1ec5d4b6_Blog-Image-4.webp" loading="lazy" alt="Insight Image" sizes="100vw" srcset="/assets/cdn/69579f06-695e43370c5edcca1ec5d4b6_Blog-Image-4-p-500.webp 500w, /assets/cdn/69579f06-695e43370c5edcca1ec5d4b6_Blog-Image-4-p-800.webp 800w, /assets/cdn/69579f06-695e43370c5edcca1ec5d4b6_Blog-Image-4-p-1080.webp 1080w, /assets/cdn/69579f06-695e43370c5edcca1ec5d4b6_Blog-Image-4.webp 1160w" class="insight-image"/></div><div class="insight-detail"><h3 class="insight-name">Chapter: local AI with a clear job</h3><p class="insight-para">Use Hermes to inspect tool calls without letting a model change the public record.</p></div></a></div></div></div></div></div></section></div><div class="footer-bg"><section class="footer" aria-label="Next steps"><h2 class="sr-only">Next steps</h2><div class="container"><div class="wrapper footer-wrapper"><div class="footer-top"><div data-w-id="55501429-edc0-238e-8edf-e5394b902f1c" class="cta-1"><span class="cta-title">Make</span><span class="cta-title">The</span><span class="cta-title start">Next</span></div><div data-w-id="55501429-edc0-238e-8edf-e5394b902f23" class="cta-1 _02"><span class="cta-title your">Useful</span><span class="cta-title">Civic</span><span class="cta-title">Project</span></div><p data-w-id="55501429-edc0-238e-8edf-e5394b902f2a" class="cta-para">Try the demo, inspect the proof, and use the source to help someone in your community.</p><div data-w-id="55501429-edc0-238e-8edf-e5394b902f2c"><a data-wf--primary-button--variant="base" data-w-id="5e04e5d2-a7d2-705e-d362-7d1873101255" href="https://shakti.dharmicdata.org" class="primary-button w-inline-block"><div class="button-texts"><div class="button-text _01">Try Shakti</div><div class="button-text _02">Try Shakti</div></div></a></div><img src="/assets/cdn/69577d21-695967c41856872ea9abfa64_Star-1.webp" loading="lazy" data-w-id="55501429-edc0-238e-8edf-e5394b902f30" alt="CTA Image" class="cta-image"/></div><div class="footer-rive desk"><canvas style="height:100%;width:100%"></canvas></div><div class="footer-rive mob"><canvas style="height:100%;width:100%"></canvas></div><div class="dharmic-it